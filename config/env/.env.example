# ----------------------------------------------------------------------------
# Example environment file. Copy to one of:
#   config/env/.env.sandbox       (ENV_TARGET=sandbox,     port 5002)
#   config/env/.env.development   (ENV_TARGET=development,  port 5001)
#   config/env/.env.production    (ENV_TARGET=production,   port 5000)
# Real .env.* files are gitignored. Start with sandbox.
# ----------------------------------------------------------------------------

# --- Plaid (https://dashboard.plaid.com) ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_for_this_environment
PLAID_ENV=sandbox                     # sandbox | development | production

# --- App auth (login page is Flask-Login + bcrypt) ---
REPORTS_USER=admin
# Generate with:  python scripts/generate_password_hash.py
REPORTS_PASS_HASH=$2b$12$replace_with_a_real_bcrypt_hash
FLASK_SECRET_KEY=change_me_to_a_long_random_string
REPORTS_SESSION_MINUTES=120

# --- Local AI (optional; requires Ollama running locally) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Plaid webhooks (optional; e.g. an ngrok https URL) ---
PLAID_WEBHOOK_URL=

# --- Misc (optional) ---
APP_USER_ID=local_user
LOG_LEVEL=INFO
PLAID_DISABLED=0                      # set 1 to run the UI without Plaid
# RAW_PLAID_CAPTURE=0                 # 1 to store raw Plaid payloads for debugging
# FIFTH_THIRD_CHECKING_ACCOUNT_ID=    # optional: pin your primary checking account id
